  .issue-item:hover { border-color: var(--border-hover); }
  .issue-top { display: flex; align-items: center; gap: 8px; margin-bottom: 7px; flex-wrap: wrap; }
  .issue-num { font-family: var(--font-mono); font-size: 10px; color: var(--text-tertiary); }
  .issue-label { font-size: 10px; padding: 2px 8px; border-radius: 3px; font-weight: 500; }
  .issue-label.bug { background: rgba(239,68,68,0.1); color: #f87171; border: 1px solid rgba(239,68,68,0.2); }
  .issue-label.feat { background: var(--accent-dim); color: #4ade80; border: 1px solid var(--accent-border); }
  .issue-label.help { background: rgba(59,130,246,0.1); color: #60a5fa; border: 1px solid rgba(59,130,246,0.2); }
  .issue-label.default { background: var(--bg-tertiary); color: var(--text-secondary); border: 1px solid var(--border); }
  .issue-repo-tag { font-family: var(--font-mono); font-size: 10px; color: var(--text-tertiary); margin-left: auto; }
