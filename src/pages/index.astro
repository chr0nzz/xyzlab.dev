  :global(.commit-msg) { color: var(--text); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  :global(.commit-time) { color: var(--text-tertiary); flex-shrink: 0; margin-left: auto; }

  /* Issues */
  .issues-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .issue-item {
    padding: 14px 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-secondary);
